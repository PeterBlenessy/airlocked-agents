# airlocked-agents — environment template (single Mac mini, everything local).
# Copy to .env and fill in. NEVER commit .env. Secrets also belong in secrets/ (gitignored).

# ---- Local model (llama.cpp, native) — the summariser, not for coding --------
# Google Gemma 4 E4B (instruct) — the small model Notesage also uses, for consistency.
MODEL_REPO=bartowski/google_gemma-4-E4B-it-GGUF
MODEL_FILE=google_gemma-4-E4B-it-Q4_K_M.gguf
MODEL_DIR=$HOME/models
LLAMA_PORT=8080
LLAMA_CTX=32768
LLAMA_API_KEY=local-only          # any non-empty value; bound to 127.0.0.1

# ---- Capture / knowledge folder (the airlock) --------------------------------
# Where airlocked-agents WRITES captures + summaries and Notesage READS/indexes them.
# REQUIRED, and NEVER hardcoded in the IaC — set it here (or via `make setup`). Typically an
# iCloud Drive folder synced across your Macs, e.g.:
#   $HOME/Library/Mobile Documents/com~apple~CloudDocs/Notesage/captures
CAPTURE_DIR=

# ---- Container runtime (runs n8n) --------------------------------------------
# apple  = Apple's native `container` (macOS 26+ Apple Silicon). DEFAULT.
# colima = lightweight open-source runtime (fallback; drop-in `docker compose`).
# docker = Docker Desktop, if you already use it.
CONTAINER_RUNTIME=apple
# Colima knobs (only used when CONTAINER_RUNTIME=colima).
COLIMA_CPUS=2
COLIMA_MEMORY=4

# ---- n8n (automation orchestrator) -------------------------------------------
# Pinned to a verified digest from Docker Hub (the docker.n8n.io mirror hits stricter anon limits).
N8N_IMAGE=docker.io/n8nio/n8n@sha256:cf11c96b0d0089bb24459bf97b445fd7008f41543b673cce4d955f7c0ed8752d
N8N_PORT=5678                                # UI on 127.0.0.1 only; no public inbound
N8N_DATA_VOLUME=n8n_data
N8N_ENCRYPTION_KEY=__set_me__                # generate ONCE: openssl rand -hex 24 ; BACK IT UP
GENERIC_TIMEZONE=Europe/Stockholm
# n8n's owner account is created once in the UI on first visit (http://127.0.0.1:5678).

# ---- Telegram (manual: token from @BotFather) --------------------------------
# Reached by POLLING (Schedule + getUpdates) — no webhook, no public inbound.
TELEGRAM_BOT_TOKEN=__from_botfather__
TELEGRAM_ALLOWED_CHAT_ID=__your_numeric_chat_id__

# ---- Mail allowlist (write path) ---------------------------------------------
# Comma-separated recipients the send path is allowed to mail.
MAIL_ALLOWLIST=anna@example.com,team@addable.se

# ---- Gmail OAuth (manual: created in Google Cloud Console) --------------------
GMAIL_OAUTH_CLIENT_ID=__from_google_cloud__
GMAIL_OAUTH_CLIENT_SECRET=__from_google_cloud__

# ---- Research models ---------------------------------------------------------
PUBLIC_RESEARCH_MODEL=anthropic/claude-sonnet-4-6   # public/non-sensitive work (cloud)
SENSITIVE_RESEARCH_MODEL=openai/local               # sensitive work → local llama.cpp
ANTHROPIC_API_KEY=__your_anthropic_key__            # used for Claude-side public research

# ---- Suna research rig (DEFERRED — not yet wired for single-box) --------------
# Suna is a heavy multi-service stack; the local-box integration is not done yet. These are
# placeholders for when it lands. See COMPONENTS.md / CHANGELOG.
SUNA_REPO=https://github.com/kortix-ai/suna.git
SUPABASE_URL=__from_supabase__
SUPABASE_ANON_KEY=__from_supabase__
SUPABASE_SERVICE_KEY=__from_supabase__
