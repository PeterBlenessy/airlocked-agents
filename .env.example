# airlocked-agents — environment template.
# Copy to .env and fill in. NEVER commit .env. Secrets also belong in secrets/ (gitignored).

# ---- Hosts -------------------------------------------------------------------
VPS_HOST=vps.example.com          # SSH-reachable host for n8n / Suna
VPS_USER=deploy                   # SSH user with sudo on the VPS
MAC_TUNNEL_IP=10.10.0.2           # the Mac's address on the WireGuard tunnel
VPS_TUNNEL_IP=10.10.0.1           # the VPS's address on the WireGuard tunnel

# ---- Local model (Mac) -------------------------------------------------------
MODEL_REPO=Qwen/Qwen3-Coder-30B-A3B-Instruct-GGUF   # HF repo for `make model`
MODEL_FILE=qwen3-coder-30b-a3b-instruct-q5_k_m.gguf  # file within the repo
MODEL_DIR=$HOME/models
LLAMA_PORT=8080
LLAMA_CTX=32768
LLAMA_API_KEY=local-only          # any non-empty value; localhost only

# ---- n8n (VPS) ---------------------------------------------------------------
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest   # pin a version tag for reproducibility
N8N_HOST=n8n.example.com           # public HTTPS hostname (behind your reverse proxy)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=__set_me__ # or generate: openssl rand -base64 18
N8N_ENCRYPTION_KEY=__set_me__      # generate ONCE: openssl rand -hex 24 ; back it up
GENERIC_TIMEZONE=Europe/Stockholm

# ---- Khoj (Mac) --------------------------------------------------------------
KHOJ_IMAGE=ghcr.io/khoj-ai/khoj:latest
KHOJ_DOCS_DIR=$HOME/Documents/research   # mounted READ-ONLY into Khoj
KHOJ_PORT=42110

# ---- Telegram (manual: token from @BotFather) --------------------------------
TELEGRAM_BOT_TOKEN=__from_botfather__
TELEGRAM_ALLOWED_CHAT_ID=__your_numeric_chat_id__

# ---- Mail allowlist (write path) ---------------------------------------------
# Comma-separated recipients the send path is allowed to mail.
MAIL_ALLOWLIST=anna@example.com,team@addable.se

# ---- Gmail OAuth (manual: created in Google Cloud Console) --------------------
GMAIL_OAUTH_CLIENT_ID=__from_google_cloud__
GMAIL_OAUTH_CLIENT_SECRET=__from_google_cloud__

# ---- Suna research rig (VPS) -------------------------------------------------
SUNA_REPO=https://github.com/kortix-ai/suna.git
SUPABASE_URL=__from_supabase__
SUPABASE_ANON_KEY=__from_supabase__
SUPABASE_SERVICE_KEY=__from_supabase__
PUBLIC_RESEARCH_MODEL=anthropic/claude-sonnet-4-6
SENSITIVE_RESEARCH_MODEL=openai/local       # routed to the Mac's local model over the tunnel
ANTHROPIC_API_KEY=__your_anthropic_key__    # used by Suna/Claude-side public research

# The local model as seen FROM the VPS, over the WireGuard tunnel. The Mac runs a
# tunnel-only proxy (socat) that listens on MAC_TUNNEL_IP:LLAMA_PORT and forwards to the
# localhost model. Point Suna's `openai/local` model at this base URL + LLAMA_API_KEY.
# Keep host/port in sync with MAC_TUNNEL_IP and LLAMA_PORT above.
LOCAL_MODEL_BASE_URL=http://10.10.0.2:8080/v1
LOCAL_MODEL_API_KEY=local-only              # must equal LLAMA_API_KEY (the proxy authenticates too)

# ---- WireGuard ---------------------------------------------------------------
WG_MAC_PRIVATE_KEY=__wg genkey__
WG_MAC_PUBLIC_KEY=__derived__
WG_VPS_PRIVATE_KEY=__wg genkey__
WG_VPS_PUBLIC_KEY=__derived__
WG_LISTEN_PORT=51820
