# mac/Brewfile — declarative Mac packages. Applied idempotently via `brew bundle`.
# Pin versions where reproducibility matters.

# Local model server (provides llama-server) — runs Gemma for summarisation.
brew "llama.cpp"

# Bridges the localhost model to the n8n container over its host-only gateway (socat).
brew "socat"

# Node — for the allowlist guard self-test (scripts/injection-selftest.sh).
brew "node"

# Convenience.
brew "jq"
brew "huggingface-cli"   # for `make model`

# The container runtime for n8n is installed by `make setup` per CONTAINER_RUNTIME (not pinned
# here): `apple` (default) installs Apple's `container`; `colima` installs colima + docker CLI +
# compose; `docker` expects Docker Desktop. See COMPONENTS.md.
